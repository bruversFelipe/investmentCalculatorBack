  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bruversFelipe/investment-calculator-api/issues"
  },
  "homepage": "https://github.com/bruversFelipe/investment-calculator-api#readme",
  "dependencies": {
    "axios": "^1.6.7",
    "backblaze-b2": "^1.7.1",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "fast-csv": "^5.0.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^6.10.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5"
  }
