  "version": "1.0.0",
  "description": "Investment Simulation Calculator API",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=14.x",
    "npm": ">=6.14.7"
  },
  "scripts": {
    "start": "node ./src/app.js",
    "dev": "nodemon",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint:check": "eslint src/**",
    "lint:fix": "eslint --fix src/**",
    "prettier:check": "prettier src/**",
    "prettier:fix": "prettier --write src/**",
    "fix": "npm run prettier:fix && npm run lint:fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bruversFelipe/investment-calculator-api.git"
