{
  "env": {
    "browser": true,
    "node": true,
    "es6": true,
    "jest": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "rules": {
    "semi": "warn",
    "quotes": [
      "error",
      "single"
    ],
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "no-redeclare": "error",
    "no-console": "off",
    "no-undef": "error"
  },
  "parserOptions": {
    "sourceType": "module",
    "ecmaVersion": 13
  }
}